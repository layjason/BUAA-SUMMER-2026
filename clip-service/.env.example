# MayoiStar CLIP 分类服务 环境变量模板
# 复制本文件为 .env 并填入实际值：
#   cp .env.example .env
#
# === 必填：Java 服务器地址 ===
# GPU 机器通过 VPN/专线连接 Java 服务器
KAFKA_BOOTSTRAP_SERVERS=<VPN_IP>:9092
RUSTFS_ENDPOINT=http://<VPN_IP>:9000

# === 以下有默认值，通常无需修改 ===

# 运行模式：kafka = Kafka Consumer + HTTP health/metrics
MODE=kafka

# 服务端口（内部暴露，不映射到宿主机；扩容时自动递增）
CLIP_PORT=8000

# Kafka consumer group（同一 group 的多个实例自动负载均衡）
KAFKA_GROUP_ID=mayoistar-clip-gpu
KAFKA_REQUEST_TOPIC=clip-classify-request
KAFKA_RESPONSE_TOPIC=clip-classify-response
CONSUMER_MAX_RETRIES=3

# S3 (RustFS) 连接凭证（需与 Java 服务器 .env 中配置一致）
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=mayoistar-media
