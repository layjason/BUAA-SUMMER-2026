          "name": "00.04 注册商家",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{merchantEmail}}\",\"password\":\"{{merchantPassword}}\",\"nickname\":\"{{merchantNickname}}\",\"name\":\"{{merchantName}}\"}"
            },
            "url": "{{baseUrl}}/identity/auth/register/merchant"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('merchant registered', () => { const body = pm.response.json(); pm.expect([200, 10001, 10002]).to.include(body.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "00.05 激活商家",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"token\":\"{{merchantActivationToken}}\"}"
            },
            "url": "{{baseUrl}}/identity/auth/activate"
          }
        },
        {
          "name": "00.06 登录商家",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{merchantEmail}}\",\"password\":\"{{merchantPassword}}\"}"
            },
            "url": "{{baseUrl}}/identity/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('merchant login success', () => { pm.expect(body.code).to.eql(200); });",
                  "if (body.code === 200) { pm.environment.set('merchantAccessToken', body.data.tokens.accessToken); pm.environment.set('merchantUserId', body.data.userId); }"
                ]
              }
            }
          ]
        },
        {
          "name": "00.07 test_user 发送好友申请",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"targetUserId\":\"{{testPeerId}}\",\"source\":\"profile\",\"message\":\"媒体鉴权测试 - 添加好友\"}"
            },
            "url": "{{baseUrl}}/social/friend-requests"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('friend request sent', () => { pm.expect(body.code).to.eql(200); });",
                  "if (body.code === 200) { pm.environment.set('friendRequestId', body.data.requestId); }"
                ]
              }
            }
          ]
        },
        {
          "name": "00.08 test_peer 同意好友申请",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{peerAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"accepted\":true}"
            },
            "url": "{{baseUrl}}/social/friend-requests/{{friendRequestId}}/decision"
          }
        },
        {
          "name": "00.09 获取私聊会话列表",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "url": "{{baseUrl}}/chat/conversations?page=1&pageSize=20"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('conversation list', () => { pm.expect(body.code).to.eql(200); });",
                  "if (body.code === 200 && body.data.items && body.data.items.length > 0) { pm.environment.set('privateConversationId', body.data.items[0].conversationId); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 私聊图片鉴权",
      "item": [
        {
          "name": "01.01 上传私聊图片",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "{{avatarFile}}" }
              ]
            },
            "url": "{{baseUrl}}/chat/media/images"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('upload private image', () => { pm.expect(body.code).to.eql(200); });",
                  "if (body.code === 200) { pm.environment.set('privateImageMediaId', body.data.mediaId); pm.environment.set('privateImageSignedUrl', body.data.url || body.data.signedUrl || ''); }"
                ]
              }
            }
          ]
        },
        {
          "name": "01.02 发送私聊图片消息",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"kind\":\"image\",\"imageMediaId\":\"{{privateImageMediaId}}\"}"
            },
            "url": "{{baseUrl}}/chat/conversations/{{privateConversationId}}/messages"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.code === 200 && body.data && body.data.image && body.data.image.signedUrl) { pm.environment.set('privateImageSignedUrl', body.data.image.signedUrl); }"
                ]
              }
            }
          ]
        },
        {
          "name": "01.03 私聊成员 test_peer 下载图片",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{peerAccessToken}}" }
            ],
            "url": "{{baseUrl}}{{privateImageSignedUrl}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('peer downloads private image', () => { pm.expect(pm.response.code).to.eql(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.04 管理员下载私聊图片",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
