            "url": "{{baseUrl}}{{privateImageSignedUrl}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin downloads private image', () => { pm.expect(pm.response.code).to.eql(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.05 匿名下载私聊图片",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}{{privateImageSignedUrl}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('anonymous download denied', () => { pm.expect(pm.response.code).to.eql(401); });"
                ]
              }
            }
          ]
        },
        {
          "name": "01.06 非成员商家下载私聊图片",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{merchantAccessToken}}" }
            ],
            "url": "{{baseUrl}}{{privateImageSignedUrl}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
