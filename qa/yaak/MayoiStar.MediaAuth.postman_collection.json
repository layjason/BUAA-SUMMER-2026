{
  "info": {
    "_postman_id": "e8a7b2c1-4d5f-6a3b-9c0d-1e2f3a4b5c6d",
    "name": "MayoiStar Media Download Authorization",
    "description": "Yaak 可导入的 MayoiStar 媒体下载鉴权接口测试集合。覆盖私聊图片、群聊图片、退出群聊后不可访问、商家资质、管理员全资源访问、签名完整性等场景。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "00 登录与注册",
      "item": [
        {
          "name": "00.01 登录 test_user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{testUserEmail}}\",\"password\":\"{{testUserPassword}}\"}"
            },
            "url": "{{baseUrl}}/identity/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('test_user login success', () => { pm.expect(body.code).to.eql(200); });",
                  "if (body.code === 200) { pm.environment.set('userAccessToken', body.data.tokens.accessToken); pm.environment.set('testUserId', body.data.userId); }"
                ]
              }
            }
          ]
        },
        {
          "name": "00.02 登录 test_peer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{testPeerEmail}}\",\"password\":\"{{testPeerPassword}}\"}"
            },
            "url": "{{baseUrl}}/identity/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('test_peer login success', () => { pm.expect(body.code).to.eql(200); });",
                  "if (body.code === 200) { pm.environment.set('peerAccessToken', body.data.tokens.accessToken); pm.environment.set('testPeerId', body.data.userId); }"
                ]
              }
            }
          ]
        },
        {
          "name": "00.03 登录 admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{adminUsername}}\",\"password\":\"{{adminPassword}}\"}"
            },
            "url": "{{baseUrl}}/admin/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
