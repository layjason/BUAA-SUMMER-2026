    {
      "name": "04 一对一聊天",
      "item": [
        {
          "name": "会话列表",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/conversations?page=1&pageSize=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "chat",
                "conversations"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = yaak.response.json().data;",
                  "if (d.items && d.items.length > 0) { yaak.environment.set(\"conversationId\", d.items[0].conversationId); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "发送文字消息",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"kind\":\"text\",\"text\":\"你好，MayoiStar QA\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/conversations/{{conversationId}}/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "chat",
                "conversations",
                "{{conversationId}}",
                "messages"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = yaak.response.json().data;",
                  "if (d.messageId) { yaak.environment.set(\"messageId\", d.messageId); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "发送表情文本消息",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
