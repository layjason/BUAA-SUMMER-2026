  "item": [
    {
      "name": "00 登录与会话变量",
      "item": [
        {
          "name": "个人用户登录 test_user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{testUserEmail}}\",\"password\":\"{{testUserPassword}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/identity/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "identity",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = yaak.response.json().data;",
                  "yaak.environment.set(\"userAccessToken\", d.tokens.accessToken);",
                  "yaak.environment.set(\"testUserId\", d.userId);",
                  "console.log(\"已设置 userAccessToken, testUserId\");"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "个人用户登录 test_peer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
