                  "const d = yaak.response.json().data;",
                  "yaak.environment.set(\"peerAccessToken\", d.tokens.accessToken);",
                  "yaak.environment.set(\"testPeerId\", d.userId);",
                  "console.log(\"已设置 peerAccessToken, testPeerId\");"
                ],
                "type": "text/javascript"
