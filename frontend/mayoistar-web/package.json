{
  "name": "mayoistar-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=5173 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "api:generate": "openapi-typescript ../../api-spec/tsp-output/openapi.yaml -o src/api/generated/openapi.ts && prettier src/api/generated/openapi.ts --write",
    "test:unit": "vitest run --environment jsdom",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "editorconfig-checker": "^6.1.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.0"
  }
}
