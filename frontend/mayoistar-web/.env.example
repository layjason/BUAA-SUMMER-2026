# =============================================================================
# mayoistar-web 环境变量模板
# =============================================================================
# 使用：cp .env.example .env
#
# 变量在 pnpm build 时打入静态包；生产配置变更后需重新构建。
# =============================================================================


# -----------------------------------------------------------------------------
# 本地联调后端（推荐）
# -----------------------------------------------------------------------------
# 1. 启动后端 http://localhost:8080
# 2. VITE_USE_MOCK=false
# 3. VITE_API_BASE_URL 留空 → vite.config.ts 代理 /admin、/identity、/media（同源，无 CORS）
# 4. pnpm dev → http://localhost:3005
#
# 管理员种子账号（非环境变量）：
#   V3 迁移 username=admin
#   V2 迁移 username=testadminyaak
# 明文密码见团队 QA 环境配置。
# -----------------------------------------------------------------------------

VITE_USE_MOCK=false
VITE_API_BASE_URL=


# -----------------------------------------------------------------------------
# 其他场景（按需取消注释，同时注释掉上方默认值）
# -----------------------------------------------------------------------------

# Mock 离线开发（不连后端）：
# VITE_USE_MOCK=true
# VITE_API_BASE_URL=
# 登录：admin / admin123

# 本地直连后端（跨域，需后端 CORS，不推荐）：
# VITE_USE_MOCK=false
# VITE_API_BASE_URL=http://localhost:8080

# 生产 — 同域反代（推荐，与本地 proxy 思路一致，API 基址留空）：
# VITE_USE_MOCK=false
# VITE_API_BASE_URL=
# Nginx 同域名转发 /admin、/identity、/media 到后端；vite.config.ts proxy 仅 dev 用，不必删除

# 生产 — 前后端不同域（build 前写入 .env.production）：
# VITE_USE_MOCK=false
# VITE_API_BASE_URL=https://api.example.com
