# MayoiStar Client 环境变量
# 复制此文件为 .env 并按需修改
# src/manifest.json 也需要修改

# ===== API 配置 =====
# 后端 API 基础地址
VITE_API_BASE_URL=http://localhost:8080

# 是否启用 Mock Server（true=使用内置 Mock，false=请求真实后端）
VITE_USE_MOCK=true

# HTTP 请求超时时间（毫秒）
VITE_REQUEST_TIMEOUT=15000

# ===== 高德地图 =====
# 高德 Web API Key（必填，用于 POI 搜索、地理编码、静态地图等）
VITE_AMAP_WEB_API_KEY=

# 高德 REST API 基础地址
VITE_AMAP_REST_BASE_URL=https://restapi.amap.com/v3

# 高德 URI 短链基础地址
VITE_AMAP_URI_BASE_URL=https://uri.amap.com

# ===== 二维码生成 =====
# 第三方二维码生成 API 基础 URL
VITE_QR_CODE_API_BASE_URL=https://api.qrserver.com/v1/create-qr-code/

# ===== Mock 占位图 =====
# Mock 数据中使用的占位图片服务基础 URL
VITE_MOCK_IMAGE_BASE_URL=https://picsum.photos
