# MayoiStar 本地接口测试配置模板
# 用法：复制为 backend/.env，按需调整端口或数据库密码。

# ===== PostgreSQL =====
POSTGRES_DB=mayoistar
POSTGRES_USER=mayoistar
POSTGRES_PASSWORD=change-me
DEV_POSTGRES_PORT=5432
POSTGRES_IMAGE=postgres:17-alpine

# ===== Redis =====
REDIS_IMAGE=redis:7-alpine
DEV_REDIS_PORT=6379
REDIS_PASSWORD=

# ===== MailHog 测试 SMTP 收件箱 =====
MAILHOG_IMAGE=mailhog/mailhog:v1.0.1
DEV_MAILHOG_SMTP_PORT=1025
DEV_MAILHOG_HTTP_PORT=8025

# ===== RustFS / S3 对象存储 =====
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
MAYOISTAR_S3_ENDPOINT=http://localhost:9000
MAYOISTAR_S3_REGION=us-east-1
MAYOISTAR_S3_BUCKET=mayoistar-media

# ===== JWT =====
MAYOISTAR_JWT_SECRET=change-me-to-a-random-secret-at-least-256-bits

# ===== SMTP 邮件：本地 MailHog，不需要真实凭据 =====
MAYOISTAR_MAIL_SENDER=mayoistar-test@example.com
MAYOISTAR_MAIL_USERNAME=
MAYOISTAR_MAIL_PASSWORD=
MAYOISTAR_MAIL_HOST=localhost
MAYOISTAR_MAIL_PORT=1025
MAYOISTAR_MAIL_SMTP_AUTH=false
MAYOISTAR_MAIL_SMTP_STARTTLS_ENABLE=false

# ===== 邮件链接基础 URL =====
MAYOISTAR_ACTIVATION_BASE_URL=http://localhost:5173/activate
MAYOISTAR_PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password
