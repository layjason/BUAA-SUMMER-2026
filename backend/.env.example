# MayoiStar 配置模板
# 复制此文件为 .env 并按需修改

# ===== PostgreSQL =====
POSTGRES_DB=mayoistar
POSTGRES_USER=mayoistar
POSTGRES_PASSWORD=change-me
DEV_POSTGRES_PORT=5432

# 可按需替换为组织内部镜像仓库中的等价 PostgreSQL 镜像
POSTGRES_IMAGE=postgres:17-alpine

# ===== Redis =====
# 可按需替换为组织内部镜像仓库中的等价 Redis 镜像
REDIS_IMAGE=redis:7-alpine
# 本地开发 Redis 端口
DEV_REDIS_PORT=6379
# Redis 密码，生产环境必填，本地开发可留空
REDIS_PASSWORD=

# ===== RustFS / S3 对象存储 =====
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
MAYOISTAR_S3_ENDPOINT=http://localhost:9000
MAYOISTAR_S3_REGION=us-east-1
MAYOISTAR_S3_BUCKET=mayoistar-media

# ===== JWT =====
# 必填，用于签发和校验 JWT，请使用足够长的随机字符串
MAYOISTAR_JWT_SECRET=change-me-to-a-random-secret-at-least-256-bits

# ===== SMTP 邮件 =====
# 必填，发件人邮箱地址
MAYOISTAR_MAIL_SENDER=mayoistar@stellan.cloud
# 必填，SMTP 登录用户名
MAYOISTAR_MAIL_USERNAME=a0bf5e001@smtp-brevo.com
# 必填，SMTP 密码或授权码
MAYOISTAR_MAIL_PASSWORD=your-smtp-password-or-auth-code
# 必填，SMTP 服务器地址
MAYOISTAR_MAIL_HOST=smtp-relay.brevo.com
# 选填，SMTP 服务器端口
MAYOISTAR_MAIL_PORT=587

# ===== 邮件链接基础 URL =====
# 必填，激活链接前缀
MAYOISTAR_ACTIVATION_BASE_URL=http://localhost:5173/activate
# 必填，密码重置链接前缀
MAYOISTAR_PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password
