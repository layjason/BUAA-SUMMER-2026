<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        MayoiStar 后端 API 使用 Authorization: Bearer JWT 传递认证凭据，不使用浏览器自动携带的
        Cookie/Session 作为 API 认证机制，因此传统 CSRF 风险模型不适用于这些 JSON API Controller。
        后续若新增 Cookie/Session 页面端点，应为页面端点单独启用 CSRF 防护。
    -->
    <Match>
        <Bug pattern="SPRING_CSRF_PROTECTION_DISABLED" />
    </Match>
    <Match>
        <Bug pattern="SPRING_CSRF_UNRESTRICTED_REQUEST_MAPPING" />
    </Match>
    <!--
        JwtService 构造器中通过 Keys.hmacShaKeyFor 初始化密钥，密钥长度校验可能抛出
        IllegalArgumentException。Finalizer 攻击在 Java 25 中已不适用（Finalizer 已被移除），
        且抛出的异常仅用于参数校验，不影响对象状态完整性。
    -->
    <Match>
        <Class name="io.github.layjason.mayoistar.service.JwtService" />
        <Bug pattern="CT_CONSTRUCTOR_THROW" />
    </Match>
    <!--
         AdminService 日志参数均为 UUID 标识符和枚举值，不含自由文本。
         reason 类用户输入已通过 sanitizeForLog 过滤 CRLF 字符。
         AdminAuthService 同。
    -->
    <Match>
        <Class name="~io\.github\.layjason\.mayoistar\.service\.Admin.*Service" />
        <Bug pattern="CRLF_INJECTION_LOGS" />
    </Match>
    <!--
         本项目中 Service 类通过构造器注入 Spring Bean，注入的 Repository 等对象由
         Spring 容器管理，不存在外部可变对象暴露风险。此模式为 Spring 推荐实践，
         不应因存储引用而产生告警。
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2" />
        <Or>
            <Class name="~io\.github\.layjason\.mayoistar\.service\.\w+ServiceImpl" />
            <Class name="~io\.github\.layjason\.mayoistar\.service\.\w+Service" />
        </Or>
    </Match>
    <!--
        ChatService 中 log 的参数均为 UUID (messageId, conversationId, userId) 或
        枚举值 (MessageKind)，不可能包含 CRLF 字符。SpotBugs 无法推断参数类型安全性。
    -->
    <Match>
        <Class name="io.github.layjason.mayoistar.service.ChatService" />
        <Bug pattern="CRLF_INJECTION_LOGS" />
    </Match>
    <Match>
        <Class name="io.github.layjason.mayoistar.service.MailService" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>
</FindBugsFilter>
